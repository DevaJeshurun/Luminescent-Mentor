# ════════════════════════════════════════════════════════════════
#  application-secrets.properties.example
#  TEMPLATE — copy this to application-secrets.properties
#  and fill in your real values. This example file IS committed.
# ════════════════════════════════════════════════════════════════

# JWT signing secret (Base64-encoded string, min 256 bits)
# Generate one with: openssl rand -base64 48
JWT_SECRET=your-base64-encoded-jwt-secret-here

# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
